{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "life-telemetry-web",
  "compatibility_date": "2026-03-10",
  "main": "./workers/app.ts",
  "vars": {
    "APP_NAME": "Life Telemetry",
    "OPENAI_CHAT_MODEL": "gpt-5-mini",
    "OPENAI_EMBEDDING_MODEL": "text-embedding-3-small"
  },
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
